### `ontozo.py`

```python
#!/usr/bin/env python3
# -*- coding: utf-8 -*-
#
# Egyszerű öntöző vezérlő – ADS1x15 (IIO) + 2 úszókapcsoló + mágnesszelep
# Pi Zero 2W / Debian
#
# GPIO kiosztás (BCM):
#   - Alsó szintkapcsoló: GPIO17 (bemenet)
#   - Felső szintkapcsoló: GPIO18 (bemenet)
#   - Mágnesszelep relé:   GPIO27 (kimenet)
#
# Talajnedvesség: ADS1x15 IIO: in_voltage0..3_raw + in_voltage*_scale
# Hiszterézis: ha bármely zóna < START_PCT  -> NYIT
#               ha minden zóna >= STOP_PCT  -> ZÁR
#
# FONTOS: A kapacitív talajnedvesség szenzorok kimenete eltérhet (nedves->nagyobb V vagy fordítva).
# Kalibráld a WET_V és DRY_V értékeket a valós mért feszültségekhez!
# Ha nálad fordított az irány, csak cseréld fel az értékeket, a kód lekezeli.
#
import os, glob, time, argparse, sys
from datetime import datetime

try:
    import RPi.GPIO as GPIO
except ImportError:
    print("Hiányzik a RPi.GPIO: sudo apt install python3-rpi.gpio", file=sys.stderr)
    sys.exit(1)

# ---------- FELHASZNÁLÓI BEÁLLÍTÁSOK (szerkeszthető konstansok) ----------
# ADS IIO eszköz automatikus keresése; ha tudod a fix elérési utat, írd be ide:
IIO_DEVICE_PATH = None  # pl. "/sys/bus/iio/devices/iio:device0" vagy None = autodetekció

# Talajnedvesség csatornák (ADS1x15 0..3)
SOIL_CHANNELS = [0, 1, 2, 3]

# Kalibráció (volt): becsüld meg / mérd ki!  WET_V = „nagyon nedves”, DRY_V = „nagyon száraz”
# Ha nálad a nedvességgel nő a feszültség, WET_V > DRY_V; ha csökken, WET_V < DRY_V.
WET_V = [2.0, 2.0, 2.0, 2.0]
DRY_V = [0.8, 0.8, 0.8, 0.8]

# Hiszterézis küszöbök (%). Példa: 30% alatt indítson, 45% felett álljon le.
START_PCT = 30.0
STOP_PCT  = 45.0

# Mintavételi periódus (másodperc)
INTERVAL_S = 5.0

# GPIO beállítások
PIN_LOWER  = 17  # alsó szintkapcsoló (üresedés jelzés)
PIN_UPPER  = 18  # felső szintkapcsoló (tele hordó jelzés)
PIN_RELAY  = 27  # mágnesszelep relé

# Úszók logikája: legtöbb esetben a kapcsoló GND-re húz záráskor -> PUD_UP + "aktív alacsony".
LOWER_ACTIVE_LOW = True   # True: zárt (LOW) = aktív
UPPER_ACTIVE_LOW = True

# Relé logika: egyes modulok "aktív alacsonyak". Állítsd ennek megfelelően.
RELAY_ACTIVE_HIGH = True  # True: HIGH = bekapcsolt relé; False: LOW = bekapcsolt relé
# -------------------------------------------------------------------------


def autodetect_iio_device():
    for d in sorted(glob.glob("/sys/bus/iio/devices/iio:device*")):
        try:
            name = open(os.path.join(d, "name"), "r", encoding="utf-8").read().strip().lower()
        except Exception:
            continue
        if any(k in name for k in ["ads1115", "ads1015", "ti-ads1015"]):
            return d
    # ha nem talált név alapján, de csak egy iio:device van, használjuk azt
    devs = sorted(glob.glob("/sys/bus/iio/devices/iio:device*"))
    return devs[0] if devs else None


def read_ads_channel(iio_dev, ch):
    raw_path   = os.path.join(iio_dev, f"in_voltage{ch}_raw")
    scale_path = os.path.join(iio_dev, f"in_voltage{ch}_scale")
    with open(raw_path, "r") as f:
        raw = int(f.read().strip())
    with open(scale_path, "r") as f:
        scale = float(f.read().strip())
    volts = raw * scale
    return raw, volts


def v_to_percent(v, wet_v, dry_v):
    # Leképezzük 0..100%-ra, bármely irányt kezelve.
    if wet_v == dry_v:
        return 0.0
    lo, hi = (dry_v, wet_v) if dry_v < wet_v else (wet_v, dry_v)
    # normál irány: dry->0%, wet->100%
    pct = 100.0 * (v - dry_v) / (wet_v - dry_v)
    # határok közé szorítás
    return max(0.0, min(100.0, pct))


def setup_gpio():
    GPIO.setmode(GPIO.BCM)
    GPIO.setwarnings(False)
    GPIO.setup(PIN_LOWER, GPIO.IN, pull_up_down=GPIO.PUD_UP)
    GPIO.setup(PIN_UPPER, GPIO.IN, pull_up_down=GPIO.PUD_UP)
    initial = GPIO.HIGH if (RELAY_ACTIVE_HIGH is False) else GPIO.LOW  # kezdetben "kikapcsolt"
    # magyarázat: ha aktív HIGH a relé, a kikapcsolt szint legyen LOW; ha aktív LOW, legyen HIGH
    GPIO.setup(PIN_RELAY, GPIO.OUT, initial=initial)


def is_active(pin, active_low=True):
    level = GPIO.input(pin)
    return (level == GPIO.LOW) if active_low else (level == GPIO.HIGH)


def set_relay(on: bool):
    if RELAY_ACTIVE_HIGH:
        GPIO.output(PIN_RELAY, GPIO.HIGH if on else GPIO.LOW)
    else:
        GPIO.output(PIN_RELAY, GPIO.LOW if on else GPIO.HIGH)


def main():
    parser = argparse.ArgumentParser(description="Egyszerű öntöző vezérlő – ADS1x15 + GPIO")
    parser.add_argument("--start", type=float, default=START_PCT, help="Indítási küszöb (%%) – ez alá esve NYIT")
    parser.add_argument("--stop",  type=float, default=STOP_PCT,  help="Leállítási küszöb (%%) – mind fölé érve ZÁR")
    parser.add_argument("--dt",    type=float, default=INTERVAL_S, help="Mintavételi periódus (s)")
    parser.add_argument("--iio",   type=str,   default=IIO_DEVICE_PATH, help="IIO eszköz elérési útja (ha üres, autodetekció)")
    parser.add_argument("--oneshot", action="store_true", help="Egyszeri kiolvasás és kilépés (nem vezérel relét).")
    args = parser.parse_args()

    iio_dev = args.iio or autodetect_iio_device()
    if not iio_dev or not os.path.isdir(iio_dev):
        print("Nem találom az ADS IIO eszközt. Ellenőrizd, hogy az ADS1x15 driver és overlay aktív!", file=sys.stderr)
        sys.exit(2)

    setup_gpio()
    watering = False

    try:
        while True:
            ts = datetime.now().strftime("%H:%M:%S")
            volts = []
            pcts  = []
            for idx, ch in enumerate(SOIL_CHANNELS):
                raw, v = read_ads_channel(iio_dev, ch)
                volts.append(v)
                pct = v_to_percent(v, WET_V[idx], DRY_V[idx])
                pcts.append(pct)
            lower_active = is_active(PIN_LOWER, LOWER_ACTIVE_LOW)
            upper_active = is_active(PIN_UPPER, UPPER_ACTIVE_LOW)

            # Konzol kimenet
            zones = " | ".join([f"Z{z}:{pcts[z]:5.1f}% ({volts[z]:.3f}V)" for z in range(len(SOIL_CHANNELS))])
            msgs = []
            if lower_active:
                msgs.append("HORDÓ: TÖLTENI KELL")
            if upper_active:
                msgs.append("HORDÓ: SZIVATTYÚ KIKAPCSOLÁS KELL")
            msg_str = (" ; ".join(msgs)) if msgs else "-"

            # Vezérlés (hiszterézis)
            any_below = any(p < args.start for p in pcts)
            all_above = all(p >= args.stop for p in pcts)

            if not args.oneshot:
                if (not watering) and any_below:
                    watering = True
                    set_relay(True)
                elif watering and all_above:
                    watering = False
                    set_relay(False)

            state = "NYITVA" if watering else "ZÁRVA"
            print(f"[{ts}] {zones}  |  SZELEP: {state}  |  {msg_str}")

            if args.oneshot:
                break
            time.sleep(args.dt)

    except KeyboardInterrupt:
        pass
    finally:
        set_relay(False)  # biztonságból zárjuk
        GPIO.cleanup()


if __name__ == "__main__":
    main()
```

